# ==============================================
# Finanzas Bot - Example environment variables
# Copy this file to .env and fill your real values.
# ==============================================

# Required in all environments
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
USER_ID=123456789
SPREADSHEET_ID=YOUR_GOOGLE_SHEETS_ID

# Optional / defaults
EXCHANGE_RATE=3.44
BASE_CURRENCY=PEN
GOOGLE_CREDENTIALS_FILE=credentials.json

# ----------------------------------------------
# Local development mode (Polling)
# ----------------------------------------------
# BOT_MODE=polling

# ----------------------------------------------
# Production mode (Webhook, e.g. Render)
# ----------------------------------------------
# BOT_MODE=webhook
# WEBHOOK_URL=https://your-service.onrender.com
# WEBHOOK_PATH=/telegram-webhook
# WEBHOOK_SECRET_TOKEN=CHANGE_ME_WITH_A_LONG_RANDOM_VALUE

# Notes:
# - In Render, PORT is injected automatically.
# - Do not commit real .env or credentials.json to git.
