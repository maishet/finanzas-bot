# ==============================================
# Finanzas Bot - Example environment variables
# Copy this file to .env and fill your real values.
# ==============================================

# Required in all environments
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
USER_ID=123456789
SPREADSHEET_ID=YOUR_GOOGLE_SHEETS_ID

# Optional / defaults
EXCHANGE_RATE=3.44
BASE_CURRENCY=PEN
GOOGLE_CREDENTIALS_FILE=credentials.json

# ----------------------------------------------
# Voice to text (es-PE)
# ----------------------------------------------
VOICE_ENABLED=true
VOICE_LOCALE=es-PE
VOICE_LANGUAGE=es
GROQ_API_KEY=YOUR_GROQ_API_KEY
# Optional override. Default: whisper-large-v3
# GROQ_TRANSCRIPTION_MODEL=whisper-large-v3

# ----------------------------------------------
# Local development mode (Polling)
# ----------------------------------------------
# BOT_MODE=polling

# ----------------------------------------------
# Production mode (Webhook, e.g. Render)
# ----------------------------------------------
# BOT_MODE=webhook
# WEBHOOK_URL=https://your-service.onrender.com
# WEBHOOK_PATH=/telegram-webhook
# WEBHOOK_SECRET_TOKEN=CHANGE_ME_WITH_A_LONG_RANDOM_VALUE

# ----------------------------------------------
# Render Free keep-alive (cron-job.org)
# ----------------------------------------------
# Set false when you migrate to a paid plan or no longer need it.
KEEPALIVE_ENABLED=true
KEEPALIVE_INTERVAL_MINUTES=10

# Keep-alive usa la misma WEBHOOK_URL (o RENDER_EXTERNAL_URL si no existe WEBHOOK_URL).
# El bot hace ping interno a WEBHOOK_URL + /healthz.
# No es necesario definir KEEPALIVE_URL manualmente.

# ----------------------------------------------
# Gmail Push (Gmail API + Pub/Sub)
# ----------------------------------------------
GMAIL_PUSH_ENABLED=true
GMAIL_CLIENT_ID=YOUR_OAUTH_CLIENT_ID
GMAIL_CLIENT_SECRET=YOUR_OAUTH_CLIENT_SECRET
GMAIL_REFRESH_TOKEN=YOUR_REFRESH_TOKEN
GMAIL_USER_EMAIL=tu_correo@gmail.com
GMAIL_PUSH_TOPIC_NAME=projects/YOUR_PROJECT_ID/topics/gmail-notifications
GMAIL_PUSH_VERIFY_TOKEN=CHANGE_ME_WITH_A_LONG_RANDOM_VALUE
GMAIL_WATCH_LABEL_IDS=INBOX
GMAIL_WATCH_RENEW_BUFFER_HOURS=24
GMAIL_ALLOWED_SENDERS=notificaciones@notificacionesbcp.com.pe

# The bot makes account matching using the Cuentas sheet column NumeroCuenta.
# Example: 19171439582091 -> BCP

# Notes:
# - In Render, PORT is injected automatically.
# - Do not commit real .env or credentials.json to git.
